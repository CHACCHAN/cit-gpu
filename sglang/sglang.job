#!/bin/bash
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --container=pytorch/pytorch:2.4.1-cuda12.1-cudnn9-devel
#SBATCH --output=logs/%j.log
#SBATCH --error=logs/%j.err

if [ -f .env ]; then
    source .env
fi

mkdir -p logs
mkdir -p .data/sglang
mkdir -p .data/open-webui
mkdir -p .data/bin
mkdir -p .data/python
mkdir -p .data/cache/triton
mkdir -p .data/cache/nv

export LC_ALL=C
export DEBIAN_FRONTEND=noninteractive
export DATA_DIR="$PWD/.data/open-webui"
export HF_HOME="$PWD/.data/sglang"
export PATH="$PWD/.data/python/bin:$PWD/.data/bin:$PATH"
export CUDA_HOME="/usr/local/cuda-12.1"
export NVCC_PREPEND_FLAGS="--allow-unsupported-compiler"
export SGLANG_CUDA_GRAPH_MAX_BATCH_SIZE=16
export TRITON_CACHE_DIR="$PWD/.data/cache/triton"
export CUDA_CACHE_PATH="$PWD/.data/cache/nv"

# 前提ツール
if [ ! -f "/usr/bin/wget" ]; then
    apt-get update && apt-get install -y curl wget ffmpeg
fi

# Portable Python3
if [ ! -f ".data/python/bin/python3" ]; then
    echo "Installing standalone portable Python 3.11..."
    wget -q https://github.com/indygreg/python-build-standalone/releases/download/20240107/cpython-3.11.7+20240107-x86_64-unknown-linux-gnu-install_only.tar.gz
    tar -xzf cpython-3.11.7+20240107-x86_64-unknown-linux-gnu-install_only.tar.gz -C .data/
    rm cpython-3.11.7+20240107-x86_64-unknown-linux-gnu-install_only.tar.gz
fi

# SGLang Open WebUI
if [ ! -f ".data/python/.install_done" ]; then
    echo "Installing SGLang (Universal Engine) and Open WebUI..."
    .data/python/bin/pip3 install --upgrade pip --root-user-action=ignore
    .data/python/bin/pip3 install "sglang[all]" open-webui --root-user-action=ignore
    touch .data/python/.install_done
fi

GPU_COUNT=${SLURM_GPUS:-1}
echo "Using Model: ${MODEL}"
echo "Running on ${GPU_COUNT} GPUs (Tensor Parallel via SGLang)"

# Run SGLang Engine
if ! pgrep -f "sglang.launch_server" > /dev/null; then
    .data/python/bin/python3 -m sglang.launch_server \
        --model-path "${MODEL}" \
        --port 11434 \
        --tp "${GPU_COUNT}" \
        --trust-remote-code > logs/sglang_daemon.log 2>&1 &
fi

echo "Waiting for SGLang server to heat up and load model..."
for i in {1..120}; do
    if (echo > /dev/tcp/127.0.0.1/11434) >/dev/null 2>&1; then
        echo "SGLang engine is up and running perfectly!"
        break
    fi
    echo "Still waiting for engine... (${i}/120)"
    sleep 5
done

# Run Open WebUI
export WEBUI_AUTH="True"
export OPENAI_API_BASE_URL="http://127.0.0.1:11434/v1"
export OPENAI_API_KEY="none"
.data/python/bin/open-webui serve --port 8080 > logs/webui.log 2>&1 &
sleep 5

# ngrok
if [ ! -f ".data/bin/ngrok" ]; then
    wget -q https://bin.equinox.io/c/bNyj1mQVY4c/ngrok-v3-stable-linux-amd64.tgz
    tar -xzf ngrok-v3-stable-linux-amd64.tgz
    mv ngrok .data/bin/ngrok
    rm ngrok-v3-stable-linux-amd64.tgz
fi

ngrok config add-authtoken "$NGROK_AUTHTOKEN"

ngrok http 11434 --domain=api.scoff-supreme-nearby.ngrok-free.dev > logs/ngrok_api.log 2>&1 &
ngrok http 8080 --domain=web.scoff-supreme-nearby.ngrok-free.dev > logs/ngrok_web.log 2>&1 &